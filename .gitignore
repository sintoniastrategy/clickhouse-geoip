# Runtime data downloaded/generated by the updater
/db/
/updater.log

# SQL files rendered from *.sql.template at run time
/sql/*.yyyymm.sql
/sql/*.main.sql

# Local Docker buildx + Go build caches (redirected here when $HOME is sandboxed)
/.cache/

# Prebuilt converter binary — shipped via GitHub releases / built on demand
/bin/mmdb2csv

# Local agent memory — not part of the public repo
/.claude/
